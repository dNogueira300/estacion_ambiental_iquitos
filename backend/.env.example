# ── PostgreSQL ──
PGHOST=localhost
PGPORT=5432
PGDATABASE=estacion
PGUSER=estacion_app
PGPASSWORD=CAMBIAR_ESTA_CLAVE

# ── MQTT (broker local en la misma VM) ──
MQTT_URL=mqtt://localhost:1883
MQTT_USER=estacion
MQTT_PASSWORD=CAMBIAR_POR_LA_CLAVE_ROTADA
MQTT_TOPIC_DATA=estacion/iquitos/lecturas
MQTT_TOPIC_STATUS=estacion/iquitos/estado
MQTT_TOPIC_COMMAND=estacion/iquitos/comandos
MQTT_TOPIC_COMMAND_RESULT=estacion/iquitos/comandos/resultado

# ── API ──
PORT=3000
# Token para endpoints de comando (recalibrar / WiFi).
# Generar con Node.js:
COMMAND_TOKEN=CAMBIAR_POR_TOKEN_LARGO_ALEATORIO

# ── Bot de Telegram (opcional: si faltan token o chat, el bot queda desactivado) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@EstacionAmbientalIquitos
# Notificar también episodios de PRECAUCION (true/false). PELIGRO siempre se notifica.
TELEGRAM_NOTIFICAR_PRECAUCION=true
# Horas de los reportes diarios (hora de Perú, separadas por coma)
TELEGRAM_HORAS_REPORTE=07:00,18:00
# Enlace que se añade al pie de todos los mensajes del bot
DASHBOARD_URL=https://estacion-ambiental-iquitos.duckdns.org/
