# ── PostgreSQL ──
PGHOST=localhost
PGPORT=5432
PGDATABASE=estacion
PGUSER=estacion_app
PGPASSWORD=CAMBIAR_ESTA_CLAVE

# ── MQTT (broker local en la misma VM) ──
MQTT_URL=mqtt://localhost:1883
MQTT_USER=estacion
MQTT_PASSWORD=CAMBIAR_POR_LA_CLAVE_ROTADA
MQTT_TOPIC_DATA=estacion/iquitos/lecturas
MQTT_TOPIC_STATUS=estacion/iquitos/estado
MQTT_TOPIC_COMMAND=estacion/iquitos/comandos
MQTT_TOPIC_COMMAND_RESULT=estacion/iquitos/comandos/resultado

# ── API ──
PORT=3000
# Token para endpoints de comando (recalibrar / WiFi). Generar con: openssl rand -hex 32
COMMAND_TOKEN=CAMBIAR_POR_TOKEN_LARGO_ALEATORIO
